{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI Token Monitor",
  "version": "0.1.0",
  "identifier": "com.ai-token-monitor.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "AI Token Monitor",
        "width": 360,
        "height": 500,
        "resizable": false,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false,
        "visible": false
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.ico"
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}